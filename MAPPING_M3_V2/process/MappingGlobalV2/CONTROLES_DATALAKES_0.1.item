    <elementParameter field="TEXT" name="UNIQUE_NAME" show="false" value="tJavaRow_3"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="/*&#10;output_row.newColumn = input_row.newColumn;&#10;output_row.newColumn1 = input_row.newColumn1;&#10;output_row.newColumn2 = input_row.newColumn2;&#10;*/&#10;//Code généré selon les schémas d'entrée et de sortie&#10;output_row.TableNom = input_row.TableNom;&#10;output_row.DBNameReplica = input_row.DBNameReplica;&#10;output_row.DBNameDatalakeTanguy = input_row.DBNameDatalakeTanguy;&#10;output_row.TableCore_NbEnreg = input_row.TableCore_NbEnreg;&#10;output_row.TableDLakeM3_NbEnreg = input_row.TableDLakeM3_NbEnreg;&#10;output_row.TableDLakeTanguy_NbEnreg = input_row.TableDLakeTanguy_NbEnreg;&#10;output_row.TableReplica_NbEnreg = input_row.TableReplica_NbEnreg;&#10;output_row.Divergence_Core_DlkM3_Tx = input_row.Divergence_Core_DlkM3_Tx;&#10;output_row.Divergence_Core_DlkM3_Nb = input_row.Divergence_Core_DlkM3_Nb;&#10;output_row.Divergence_DlkM3_DlkTanguy_Tx = input_row.Divergence_DlkM3_DlkTanguy_Tx;&#10;output_row.Divergence_DlkM3_DlkTanguy_Nb = input_row.Divergence_DlkM3_DlkTanguy_Nb;&#10;output_row.Divergence_Core_Replica_Tx = input_row.Divergence_Core_Replica_Tx;&#10;output_row.Divergence_Core_Replica_Nb = input_row.Divergence_Core_Replica_Nb;&#10;output_row.Table_DlkM3_Doublon = input_row.Table_DlkM3_Doublon;&#10;output_row.Avertissement = input_row.Avertissement;&#10;output_row.DateInfo = input_row.DateInfo;&#10;output_row.HeureInfo = input_row.HeureInfo;&#10;&#10;&#10;&#10;//Code généré selon les schémas d'entrée et de sortie&#10;output_row.TableNom = input_row.TableNom;&#10;output_row.DBNameReplica = input_row.DBNameReplica;&#10;output_row.DBNameDatalakeTanguy = input_row.DBNameDatalakeTanguy;&#10;output_row.TableCore_NbEnreg = input_row.TableCore_NbEnreg;&#10;output_row.TableDLakeM3_NbEnreg = input_row.TableDLakeM3_NbEnreg;&#10;output_row.TableDLakeTanguy_NbEnreg = input_row.TableDLakeTanguy_NbEnreg;&#10;output_row.TableReplica_NbEnreg = input_row.TableReplica_NbEnreg;&#10;output_row.Divergence_Core_DlkM3_Tx = input_row.Divergence_Core_DlkM3_Tx;&#10;output_row.Divergence_Core_DlkM3_Nb = input_row.Divergence_Core_DlkM3_Nb;&#10;output_row.Divergence_DlkM3_DlkTanguy_Tx = input_row.Divergence_DlkM3_DlkTanguy_Tx;&#10;output_row.Divergence_DlkM3_DlkTanguy_Nb = input_row.Divergence_DlkM3_DlkTanguy_Nb;&#10;output_row.Divergence_Core_Replica_Tx = input_row.Divergence_Core_Replica_Tx;&#10;output_row.Divergence_Core_Replica_Nb = input_row.Divergence_Core_Replica_Nb;&#10;output_row.Table_DlkM3_Doublon = input_row.Table_DlkM3_Doublon;&#10;output_row.Avertissement = input_row.Avertissement;&#10;output_row.DateInfo = input_row.DateInfo;&#10;output_row.HeureInfo = input_row.HeureInfo;&#10;&#10;&#10;//output_row.VariationDlkTAnguy = input_row.VariationDlkTAnguy;&#10;&#10;&#10;if (input_row.VariationCore == null||(Double.isNaN(input_row.VariationCore))||(Double.isInfinite(input_row.VariationCore))){//isInfinite&#10;&#9;output_row.VariationCore = (double)0;&#10;}else{&#10;&#9;output_row.VariationCore = input_row.VariationCore;&#10;}&#10;&#10;if ((input_row.VariationReplica == null)||(Double.isNaN(input_row.VariationReplica))||(Double.isInfinite(input_row.VariationReplica))){//Double.isNaN(doubleValue)&#10;&#9;output_row.VariationReplica = (double)0;&#10;}else{&#10;&#9;output_row.VariationReplica = input_row.VariationReplica;&#10;}&#10;&#10;if (input_row.VariationDlkTAnguy == null||(Double.isNaN(input_row.VariationDlkTAnguy))||(Double.isInfinite(input_row.VariationDlkTAnguy))){&#10;&#9;output_row.VariationDlkTAnguy = (double)0;&#10;}else{&#10;&#9;output_row.VariationDlkTAnguy = input_row.VariationDlkTAnguy;&#10;}&#10;&#10;output_row.Avertissement=0;&#10;output_row.Divergence_Core_DlkM3_Tx &#9;=0;&#10;output_row.Divergence_Core_DlkM3_Tx =0;&#10;output_row.Divergence_Core_DlkM3_Nb &#9;=0;&#10;output_row.Divergence_DlkM3_DlkTanguy_Nb =0;&#10;output_row.Divergence_Core_Replica_Tx = (double)0;&#10;&#9;&#10;//output_row.Table_DlkM3_Doublon = 0;&#10;if ((output_row.Table_DlkM3_Doublon &gt; 0)) {&#10;&#9;output_row.Table_DlkM3_Doublon = input_row.Table_DlkM3_Doublon;&#10;}&#10;&#10;&#10;if ((output_row.Table_DlkM3_Doublon &gt; 0) &amp;&amp; !(output_row.Table_DlkM3_Doublon == null)  ) {&#10;&#9;output_row.Avertissement=1;&#10;}&#10;&#10;&#10;//Calcul des taux de divergence &amp; des differnences CoreM3 &lt;--&gt; DatalakeM3&#10;if (!(output_row.TableCore_NbEnreg == null) &amp;&amp; !(output_row.TableDLakeM3_NbEnreg == null)){&#10;&#9;if ( (output_row.TableCore_NbEnreg &gt;0 ) &amp;&amp; (output_row.TableDLakeM3_NbEnreg&gt;0))&#10;&#9;{&#10;&#9;&#9;Double MyResult1_Core_JDBC = ((output_row.TableDLakeM3_NbEnreg.doubleValue() / output_row.TableCore_NbEnreg.doubleValue()))*100 ;&#10;&#9;&#9;output_row.Divergence_Core_DlkM3_Tx = Math.round(MyResult1_Core_JDBC*100);&#10;&#9;&#9;output_row.Divergence_Core_DlkM3_Tx = output_row.Divergence_Core_DlkM3_Tx/100;&#10;&#9;&#9;output_row.Divergence_Core_DlkM3_Nb &#9;=output_row.TableCore_NbEnreg-output_row.TableDLakeM3_NbEnreg;&#10;&#9;}else{&#10;&#9;&#9;output_row.Divergence_Core_DlkM3_Tx = -1;&#10;&#9;}  &#10;}&#10;/*&#10;output_row.Divergence_DlkM3_DlkTanguy_Tx = input_row.Divergence_DlkM3_DlkTanguy_Tx;&#10;output_row.Divergence_DlkM3_DlkTanguy_Nb = input_row.Divergence_DlkM3_DlkTanguy_Nb;&#10;&#10;*/&#10;//Calcul des taux de divergence &amp; des differnences DatalakeM3 &lt;--&gt; DatalLake Tanguy&#10;if (!(output_row.TableDLakeTanguy_NbEnreg == null)&amp;&amp; !(output_row.TableDLakeM3_NbEnreg == null)){&#10;&#9;if ((output_row.TableDLakeM3_NbEnreg &gt;0 ) &amp;&amp; (output_row.TableDLakeM3_NbEnreg&gt;0)   )&#10;&#9;{&#9;&#10;&#9;&#9;Double MyResult2_JDBC_MariaDB = ((output_row.TableDLakeTanguy_NbEnreg.doubleValue() / output_row.TableDLakeM3_NbEnreg.doubleValue()))*100 ;&#10;&#9;&#9;output_row.Divergence_DlkM3_DlkTanguy_Tx=MyResult2_JDBC_MariaDB;&#10;&#9;&#9;output_row.Divergence_DlkM3_DlkTanguy_Nb=output_row.TableDLakeTanguy_NbEnreg-output_row.TableDLakeM3_NbEnreg;&#10;&#9;&#9;//output_row.Divergence_Core_DlkM3_Tx = Math.round(MyResult2_JDBC_MariaDB*100);&#10;&#9;&#9;//output_row.Divergence_Core_DlkM3_Tx = output_row.Divergence_Core_DlkM3_Tx/100;&#10;&#9;&#9;output_row.Divergence_DlkM3_DlkTanguy_Nb =output_row.TableDLakeM3_NbEnreg-output_row.TableDLakeTanguy_NbEnreg;&#10;&#9;}else{&#10;&#9;&#9;output_row.Divergence_DlkM3_DlkTanguy_Tx = -2;&#10;&#9;}  &#10;}&#10;&#10;//Calcul des taux de divergence &amp; des differnences CoreM3 &lt;--&gt; Replica&#10;if (!(output_row.TableCore_NbEnreg == null) &amp;&amp; !(output_row.TableReplica_NbEnreg == null)){&#10;&#9;if ( (output_row.TableCore_NbEnreg &gt;0 ) &amp;&amp; (output_row.TableReplica_NbEnreg&gt;0))&#10;&#9;{&#10;&#9;&#9;Double MyResult1_Core_Replica = ((output_row.TableReplica_NbEnreg.doubleValue() / output_row.TableCore_NbEnreg.doubleValue()))*100 ;&#10;&#9;&#9;output_row.Divergence_Core_Replica_Tx = (double)Math.round(MyResult1_Core_Replica*100);&#10;&#9;&#9;output_row.Divergence_Core_Replica_Tx = output_row.Divergence_Core_Replica_Tx/(double)100;&#10;&#9;&#9;output_row.Divergence_Core_Replica_Nb &#9;=output_row.TableCore_NbEnreg-output_row.TableReplica_NbEnreg;&#10;&#9;}else{&#10;&#9;&#9;output_row.Divergence_Core_Replica_Tx = (double)-1;&#10;&#9;}  &#10;}&#10;&#10;//Définir avertissement à 1 si certaines conditions sont remplies&#10;if&#10;(&#10;&#9;((output_row.Divergence_Core_DlkM3_Tx &gt;110 || output_row.Divergence_Core_DlkM3_Tx &lt;90 || output_row.Divergence_Core_DlkM3_Nb &gt; 1000) &amp;&amp; output_row.Divergence_Core_DlkM3_Tx &gt; 0 ) &#10;||&#10;&#9;((output_row.Divergence_DlkM3_DlkTanguy_Tx &gt; 110 || output_row.Divergence_DlkM3_DlkTanguy_Tx &lt;90 || output_row.Divergence_DlkM3_DlkTanguy_Nb &gt; 1000) &amp;&amp; output_row.Divergence_DlkM3_DlkTanguy_Tx &gt;0 )&#10;||&#10;&#9;((output_row.Divergence_Core_Replica_Tx &gt; 110 || output_row.Divergence_Core_Replica_Tx &lt;90 || output_row.Divergence_Core_Replica_Nb &gt; 1000) &amp;&amp; output_row.Divergence_Core_Replica_Tx &gt;0 )&#10;)&#10;&#9;&#10;{&#10;&#9;&#9;output_row.Avertissement =1;&#10;}&#10;"/>
