  <node componentName="tMysqlInput" componentVersion="0.102" offsetLabelX="0" offsetLabelY="0" posX="80" posY="200">
    <elementParameter field="TEXT" name="UNIQUE_NAME" show="false" value="tDBInput_1"/>
    <elementParameter field="CLOSED_LIST" name="DB_VERSION" show="false" value="MYSQL_8"/>
