    <elementParameter field="TEXT" name="USER" show="false" value="&quot;&quot;"/>
    <elementParameter field="PASSWORD" name="PASS" show="false" value="enc:system.encryption.key.v1:CS6Vy/6lWZVAOK7guuYQR8umVm1GEOv63viaQR05"/>
    <elementParameter field="DBTABLE" name="TABLE" value="&quot;&quot;"/>
    <elementParameter field="QUERYSTORE_TYPE" name="QUERYSTORE" value="&quot;&quot;"/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:REPOSITORY_QUERYSTORE_TYPE" show="false" value=""/>
    <elementParameter field="TECHNICAL" name="QUERYSTORE:QUERYSTORE_TYPE" value="BUILT_IN"/>
    <elementParameter field="GUESS_SCHEMA" name="GUESS_SCHEMA" value="&quot;&quot;"/>
    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;SELECT TABLE_NAME &#13;&#10;FROM INFORMATION_SCHEMA.TABLES &#13;&#10;WHERE TABLE_SCHEMA ='&quot;+context.MySQL_MSU_DatalakeM3_Database+&quot;'  &#13;&#10;and LENGTH(TABLE_NAME)=6  &#13;&#10; and TABLE_NAME not in ('MPOPLP','mpoplp','FGLEDX','MCELEM','MCHEAD','FBAVAL','FCAAVP','MITSTA','MPOEXP','OOLICH','OPRBAS','OSASTD') -- MCELEM&#13;&#10;-- and TABLE_NAME  in ('MDOPLP','MFTRNS','MGHEAD','MGLINE','MHDISH','MHDISL','MCWCCO') -- MFTRNS MGLINE MHDISL&#13;&#10;and TABLE_NAME &gt;'OSASTD'&#13;&#10;ORDER BY TABLE_NAME &#13;&#10;-- limit 32 &#13;&#10;;&quot;"/>
    <elementParameter field="LABEL" name="NOTE" show="false" value="This option only applies when deploying and running in the Talend Runtime"/>
    <elementParameter field="CHECK" name="SPECIFY_DATASOURCE_ALIAS" show="false" value="false"/>
    <elementParameter field="TEXT" name="DATASOURCE_ALIAS" show="false" value="&quot;&quot;"/>
    <elementParameter field="MAPPING_TYPE" name="MAPPING" show="false" value="mysql_id"/>
    <elementParameter field="TEXT" name="PROPERTIES" show="false" value="&quot;noDatetimeStringSync=true&quot;"/>
    <elementParameter field="ENCODING_TYPE" name="ENCODING" show="false" value="&quot;ISO-8859-15&quot;"/>
    <elementParameter field="TECHNICAL" name="ENCODING:ENCODING_TYPE" value="ISO-8859-15"/>
    <elementParameter field="CHECK" name="ENABLE_STREAM" value="false"/>
    <elementParameter field="CHECK" name="TRIM_ALL_COLUMN" value="false"/>
    <elementParameter field="TABLE" name="TRIM_COLUMN">
      <elementValue elementRef="SCHEMA_COLUMN" value="TABLE_NAME"/>
      <elementValue elementRef="TRIM" value="false"/>
    </elementParameter>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tDBInput_1">
      <column comment="" key="false" length="-1" name="TABLE_NAME" nullable="true" originalLength="-1" pattern="" precision="-1" sourceType="VARCHAR" type="id_String" usefulColumn="true"/>
    </metadata>
