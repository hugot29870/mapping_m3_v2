    <elementParameter field="TEXT" name="UNIQUE_NAME" show="false" value="tJava_1"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="&#10;//context.Schema_ListeClePrimaire=row25.ListeClePrimaire;&#10;  //CONO`,`WHLO`,`ITNO`,`WHSL`,`BANO`,`CAMU`,`TTYP`,`RIDN`,`RIDO`,`RIDL`,`RIDX`,`RIDI`,`PLSX`,`SOFT&#10;  &#10;  &#10;String[] sousChaines = (&quot;&quot;+context.Schema_ListeClePrimaire.replaceAll(&quot;`&quot;,&quot;&quot;)+&quot;&quot;).split(&quot;,&quot;);&#10;// Conversion en ArrayList&#10;ArrayList&lt;String&gt; liste = new ArrayList&lt;&gt;(Arrays.asList(sousChaines));&#10;String WhereCondition=&quot;&quot;;&#10;//liste.size()&#10;String SQLSimpleQuote = &quot;''&quot;;&#10;Integer ListSizeFor = liste.size();&#10;WhereCondition=&quot;concat(&quot;;&#10; for (int i = 0; i &lt; ListSizeFor ; i++) {&#10; &#9;String CondP1=&quot;'''&quot;+liste.get(i)+&quot;=''',&quot;;&#10; &#9;String CondP2=&quot;CAST(&quot;+liste.get(i)+&quot; as CHAR)&quot;;&#10; &#9;String CondP3Ext=&quot;,'''' ,','&quot;; &#9;&#10; &#9;&#10;// &#9;WhereCondition+=&quot;concat('&quot;+liste.get(i)+&quot;=,`&quot;+liste.get(i)+&quot;`)&quot;;&#10;//  &#9;WhereCondition+=&quot;concat(&quot;+CondP1+&quot;,&quot;+CondP2+&quot;)&quot;+CondP3Ext;&#10; &#9;WhereCondition+=CondP1+CondP2+CondP3Ext;&#10;&#9;if(i+1&lt;ListSizeFor){&#10;//&#9;&#9;WhereCondition+=&quot;+' AND '+&quot;;&#10;&#9;&#9;WhereCondition+=&quot;,&quot;;&#10;&#9;}else{&#10;&#9;&#9;WhereCondition+=&quot;)&quot;;&#9;&#10;&#9;}&#10;}&#10;&#10;    //System.out.println(WhereCondition);&#10;//  output_row.Req = &quot;SELECT &quot;+WhereCondition+&quot;, `timestamp`  FROM   'MITALO' ; &quot;;&#10;//SELECT concat('CONO=''',`CONO`)+''''concat('WHLO=''',`WHLO`)+''''c&#10;  context.Schema_Req_ReplicaSelect= &quot;SELECT &quot;+WhereCondition+&quot; as UPK, `timestamp`  FROM   &quot;+context.NomTable+&quot; ; &quot;; //limit 10&#10;  //concat('''CONO='''  , CAST(CONO as CHAR),'''' )&#10;System.out.println( context.Schema_Req_ReplicaSelect);"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_1"/>
  </node>
