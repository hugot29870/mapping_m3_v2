  <node componentName="tJavaRow" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="1120" posY="520">
    <elementParameter field="TEXT" name="UNIQUE_NAME" show="false" value="tJavaRow_3"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="//Code généré selon les schémas d'entrée et de sortie&#10;&#13;&#10;output_row.ListeClePrimaire = input_row.ListeClePrimaire;&#13;&#10;//output_row.Req = &quot; select 'MITALO', count(*) from (select `&quot;+row24.ListeClePrimaire+&quot;`, count(*) as NB_DOUBLONS from MITALO group by `&quot;+row24.ListeClePrimaire+&quot;` having count(*) &gt;1 order by `&quot;+row24.ListeClePrimaire+&quot;`)&quot;;&#10;&#10;&#10;&#10;output_row.Req = &quot;SELECT `&quot;+row25.ListeClePrimaire+&quot;`  FROM   infor.IncludeDeleted('&quot;+context.NomTable+&quot;') WHERE &quot;+context.NomTable+&quot;.`timestamp` &gt;'2025-10-07T11:16:20.806Z' AND DELETED ='true' &quot;; // LIMIT 100  LIMIT 10&#10;&#10;context.Schema_ListeClePrimaire=row25.ListeClePrimaire;&#10;  //CONO`,`WHLO`,`ITNO`,`WHSL`,`BANO`,`CAMU`,`TTYP`,`RIDN`,`RIDO`,`RIDL`,`RIDX`,`RIDI`,`PLSX`,`SOFT&#10;  &#10;  &#10;String[] sousChaines = (&quot;&quot;+row24.ListeClePrimaire.replaceAll(&quot;`&quot;,&quot;&quot;)+&quot;&quot;).split(&quot;,&quot;);&#10;// Conversion en ArrayList&#10;ArrayList&lt;String&gt; liste = new ArrayList&lt;&gt;(Arrays.asList(sousChaines));&#10;String WhereCondition=&quot;&quot;;&#10;//liste.size()&#10;String SQLSimpleQuote = &quot;''&quot;;&#10;Integer ListSizeFor = liste.size();&#10;&#10; for (int i = 0; i &lt; ListSizeFor ; i++) {&#10; &#9;String CondP1=&quot;'&quot;+liste.get(i)+&quot;='''&quot;;&#10; &#9;String CondP2=&quot;`&quot;+liste.get(i)+&quot;`&quot;;&#10;// &#9;String CondP3Ext=&quot;+'''&quot;+&quot;,&quot;+&quot;'''&quot;;&#10; &#9;String CondP3Ext=&quot;+'''&quot;;&#10; &#9;&#10;  &#9;WhereCondition+=&quot;concat(&quot;+CondP1+&quot;,&quot;+CondP2+&quot;)&quot;+CondP3Ext;&#10; &#9;&#10;&#9;if(i+1&lt;ListSizeFor){&#10;&#9;&#9;WhereCondition+=&quot;,&quot;+&quot;'''&quot;;&#10;&#9;&#9;WhereCondition+=&quot;+&quot;;&#10;&#10;&#9;}else{&#10;&#9;&#10;&#9;&#9;WhereCondition+=&quot;'''&quot;;&#10;&#9;}&#10;}&#10;&#10;    //System.out.println(WhereCondition);&#10;  output_row.Req = &quot;SELECT &quot;+WhereCondition+&quot; as UPK , `timestamp`  FROM   infor.IncludeDeleted('&quot;+context.NomTable+&quot;') WHERE &quot;+context.NomTable+&quot;.`timestamp` &gt;'2025-10-01T11:16:20.806Z' AND DELETED ='true'  &quot; ; //LIMIT 10&#10;&#10;//LIMIT 100 &quot;;&#10;  "/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;&#10;import java.util.ArrayList;&#10;import java.util.Arrays;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJavaRow_3">
